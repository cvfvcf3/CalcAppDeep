<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    android:padding="16dp">

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tabBasic"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Basic"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:gravity="center"
            android:background="@drawable/tab_selected"/>

        <TextView
            android:id="@+id/tabScientific"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Scientific"
            android:textColor="@color/gray"
            android:textSize="16sp"
            android:gravity="center"
            android:background="@drawable/tab_unselected"/>

        <TextView
            android:id="@+id/tabHistory"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="History"
            android:textColor="@color/gray"
            android:textSize="16sp"
            android:gravity="center"
            android:background="@drawable/tab_unselected"/>
    </LinearLayout>

    <!-- Display -->
    <TextView
        android:id="@+id/tvExpression"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.4"
        android:gravity="bottom|end"
        android:text="140 +"
        android:textSize="28sp"
        android:textColor="#888888"
        android:fontFamily="monospace"/>

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.4"
        android:gravity="bottom|end"
        android:text="140"
        android:textSize="56sp"
        android:textColor="@color/white"
        android:fontFamily="monospace"
        android:layout_marginBottom="20dp"/>

    <!-- Keypad Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:rowCount="5"
        android:columnCount="4"
        android:useDefaultMargins="true">

        <!-- Row 1 -->
        <Button android:text="C" style="@style/OperatorButton"/>
        <Button android:text="+/-" style="@style/OperatorButton"/>
        <Button android:text="%" style="@style/OperatorButton"/>
        <Button android:text="÷" style="@style/OperatorButton"/>

        <!-- Row 2 -->
        <Button android:text="7" style="@style/NumberButton"/>
        <Button android:text="8" style="@style/NumberButton"/>
        <Button android:text="9" style="@style/NumberButton"/>
        <Button android:text="×" style="@style/OperatorButton"/>

        <!-- Row 3 -->
        <Button android:text="4" style="@style/NumberButton"/>
        <Button android:text="5" style="@style/NumberButton"/>
        <Button android:text="6" style="@style/NumberButton"/>
        <Button android:text="-" style="@style/OperatorButton"/>

        <!-- Row 4 -->
        <Button android:text="1" style="@style/NumberButton"/>
        <Button android:text="2" style="@style/NumberButton"/>
        <Button android:text="3" style="@style/NumberButton"/>
        <Button android:text="+" style="@style/OperatorButton"/>

        <!-- Row 5 -->
        <Button android:text="0" style="@style/NumberButton" android:layout_columnSpan="2"/>
        <Button android:text="." style="@style/NumberButton"/>
        <Button android:text="=" style="@style/EqualsButton"/>

    </GridLayout>
</LinearLayout>
